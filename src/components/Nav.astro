---
const links = [
  { href: '#home', label: 'Home', num: '01' },
  { href: '#about', label: 'About', num: '02' },
  { href: '#projects', label: 'Projects', num: '03' },
  { href: '#services', label: 'Services', num: '04' },
  { href: '#contact', label: 'Contact', num: '05' },
];
---

<nav class="nav">
  <div class="nav-brand">
    <a href="#home" class="nav-logo">JV</a>
  </div>

  <ul class="nav-links">
    {links.map((link) => (
      <li>
        <a href={link.href} class="nav-link" data-num={link.num}>
          <span class="nav-link-text">{link.label}</span>
        </a>
      </li>
    ))}
  </ul>

  <div class="nav-footer">
    <div class="nav-line"></div>
    <span class="nav-copyright">© 2026</span>
  </div>
</nav>

<!-- Mobile Nav Toggle -->
<button class="nav-toggle" aria-label="Toggle navigation">
  <span></span>
  <span></span>
</button>

<style>
  .nav {
    position: fixed;
    left: 0;
    top: 0;
    width: 220px;
    height: 100vh;
    height: 100dvh;
    background: var(--black);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-lg) var(--space-md);
    z-index: 1000;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .nav-brand {
    margin-bottom: var(--space-lg);
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    position: relative;
    display: inline-block;
  }

  .nav-logo::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(to right, var(--accent), var(--accent-dim));
  }

  .nav-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0.6rem 0;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--text-muted);
    transition: all var(--duration-fast) var(--ease-out);
    position: relative;
    border-left: 2px solid transparent;
    border-radius: 2px;
  }

  .nav-link::before {
    content: attr(data-num);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
    width: 2rem;
    opacity: 0;
    transform: translateX(-8px);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text-primary);
    background: rgba(200, 63, 109, 0.06);
    border-left: 2px solid var(--accent);
    padding-left: 0.5rem;
  }

  .nav-link:hover::before,
  .nav-link.active::before {
    opacity: 1;
    transform: translateX(0);
    color: var(--accent);
  }

  .nav-link.active .nav-link-text::after {
    content: '';
    position: absolute;
    left: 2rem;
    bottom: 0.5rem;
    width: calc(100% - 2rem);
    height: 1px;
    background: var(--accent-dim);
  }

  .nav-link-text {
    position: relative;
  }

  .nav-footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .nav-line {
    width: 30px;
    height: 1px;
    background: var(--border-light);
  }

  .nav-copyright {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  /* Mobile Toggle */
  .nav-toggle {
    display: none;
    position: fixed;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 1001;
    width: 40px;
    height: 40px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 6px;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--text-primary);
    transition: all var(--duration-normal) var(--ease-out);
  }

  @media (max-width: 900px) {
    .nav {
      transform: translateX(-100%);
    }

    .nav.open {
      transform: translateX(0);
    }

    .nav-toggle {
      display: flex;
    }

    .nav-toggle.open span:first-child {
      transform: rotate(45deg) translate(2.5px, 2.5px);
    }

    .nav-toggle.open span:last-child {
      transform: rotate(-45deg) translate(2.5px, -2.5px);
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.querySelector('.nav');

  toggle?.addEventListener('click', () => {
    toggle.classList.toggle('open');
    nav?.classList.toggle('open');
  });

  // Close nav on link click (mobile)
  document.querySelectorAll('.nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      toggle?.classList.remove('open');
      nav?.classList.remove('open');
    });
  });
</script>
