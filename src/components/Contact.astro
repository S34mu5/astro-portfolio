---
---

<section id="contact" class="contact section">
  <div class="contact-inner section-inner">
    <div class="contact-grid">
      <!-- Left -->
      <div class="contact-left">
        <div class="section-label reveal">
          <span>Contact</span>
        </div>

        <h2 class="contact-title reveal reveal-delay-1">
          Let's build
          <em>something</em>
          together
        </h2>

        <p class="contact-text reveal reveal-delay-2">
          Have a project in mind or just want to say hello?
          I'd love to hear from you.
        </p>

        <div class="contact-info reveal reveal-delay-3">
          <div class="contact-info-item">
            <span class="contact-info-label">Based in</span>
            <span class="contact-info-value">Europe</span>
          </div>
          <div class="contact-info-item">
            <span class="contact-info-label">Status</span>
            <span class="contact-info-value contact-info-available">
              <span class="contact-available-dot"></span>
              Open to opportunities
            </span>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="contact-right reveal reveal-delay-2">
        <form class="contact-form" id="contact-form" novalidate>
          <div class="form-group">
            <label class="form-label" for="name">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              class="form-input"
              placeholder="Your name"
              required
            />
            <div class="form-line"></div>
          </div>

          <div class="form-group">
            <label class="form-label" for="email">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="your@email.com"
              required
            />
            <div class="form-line"></div>
          </div>

          <div class="form-group">
            <label class="form-label" for="message">Message</label>
            <textarea
              id="message"
              name="message"
              class="form-input form-textarea"
              placeholder="Tell me about your project..."
              rows="5"
            ></textarea>
            <div class="form-line"></div>
          </div>

          <button type="submit" class="form-submit magnetic">
            <span>Send Message</span>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    padding-left: calc(220px + var(--gutter));
    background: var(--black);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .contact-title {
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    margin-bottom: var(--space-md);
  }

  .contact-title em {
    background: linear-gradient(to right, var(--accent), var(--accent-dim));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  .contact-text {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  /* Info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-info-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .contact-info-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .contact-info-value {
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  .contact-info-available {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .contact-available-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4adede;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .form-group {
    position: relative;
  }

  .form-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
  }

  .form-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    padding: 0.75rem 0;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text-primary);
    outline: none;
    transition: border-color var(--duration-normal) var(--ease-out);
    resize: none;
  }

  .form-input::placeholder {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .form-input:focus {
    border-color: var(--accent);
    box-shadow: 0 2px 15px rgba(200, 63, 109, 0.15);
  }

  .form-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(to right, var(--accent), var(--accent-dim));
    transition: width var(--duration-slow) var(--ease-out);
  }

  .form-input:focus ~ .form-line {
    width: 100%;
  }

  .form-textarea {
    min-height: 120px;
    line-height: 1.7;
  }

  .form-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    align-self: flex-start;
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    border-radius: 2px;
    transition: all var(--duration-normal) var(--ease-out);
    margin-top: var(--space-sm);
    position: relative;
    overflow: hidden;
  }

  .form-submit::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transition: left 0.7s ease;
  }

  .form-submit:hover::before {
    left: 100%;
  }

  .form-submit:hover {
    background: linear-gradient(135deg, var(--accent-bright), var(--accent));
    box-shadow: 0 8px 30px var(--accent-glow), 0 0 15px var(--accent-glow);
  }

  .form-submit:hover svg {
    transform: translateX(4px);
  }

  .form-submit svg {
    transition: transform var(--duration-normal) var(--ease-out);
  }

  @media (max-width: 900px) {
    .contact {
      padding-left: var(--gutter);
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    if (!name) {
      (document.getElementById('name') as HTMLInputElement).focus();
      return;
    }
    // Placeholder: show success feedback
    const btn = form.querySelector('.form-submit span');
    if (btn) btn.textContent = 'Message Sent!';
    setTimeout(() => {
      if (btn) btn.textContent = 'Send Message';
      form.reset();
    }, 2500);
  });
</script>
